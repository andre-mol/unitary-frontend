# Copie para .env.local ou .env.development (npm run dev não lê .env.production)

# Demo sem backend (currículo / preview local)
VITE_DEMO_MODE=true

# Login da demo — use as MESMAS variáveis no .env.local e na Vercel (valores iguais ao do README)
# Se omitir ambas, o login padrão é demo@unitary.app / demo (documente no README se usar esse padrão)
# VITE_DEMO_LOGIN_EMAIL=demo@unitary.app
# VITE_DEMO_LOGIN_PASSWORD=sua_senha_de_vitrine

# Produção real — só use com projeto Supabase válido
# VITE_DEMO_MODE=false
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=
